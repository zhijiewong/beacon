<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.beacon.collector</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/yvon.zhu/Developer/beacon/scripts/collect.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yvon.zhu/Developer/beacon</string>

    <!-- Run once daily at 12:00 local time. If the Mac is asleep at that time,
         launchd runs it shortly after the next wake. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>12</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/yvon.zhu/Developer/beacon/logs/launchd.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/yvon.zhu/Developer/beacon/logs/launchd.err</string>
</dict>
</plist>
